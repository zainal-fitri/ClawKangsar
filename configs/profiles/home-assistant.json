{
  "log_level": "INFO",
  "system_prompt": "You are ClawKangsar, a professional assistant running on a Raspberry Pi. Keep responses concise and use your browser tool only when real-time data is needed.",
  "llm": {
    "enabled": false,
    "provider": "openai_compat",
    "auth_method": "api_key",
    "base_url": "https://api.openai.com/v1",
    "api_key": "",
    "api_key_env": "OPENAI_API_KEY",
    "codex_auth_path": "",
    "model": "set-your-model",
    "temperature": 0.2,
    "max_tokens": 512,
    "timeout_seconds": 60,
    "history_messages": 16
  },
  "whatsapp": {
    "enabled": false,
    "session_dsn": "file:clawkangsar_whatsapp.db?_foreign_keys=on"
  },
  "telegram": {
    "enabled": false,
    "token": "",
    "allow_list": [
      123456789
    ]
  },
  "browser": {
    "idle_timeout_seconds": 300
  },
  "storage": {
    "session_dir": "data/sessions"
  },
  "health": {
    "enabled": true,
    "host": "0.0.0.0",
    "port": 18080
  },
  "tools": {
    "web_fetch_timeout_seconds": 20,
    "web_fetch_max_chars": 4000,
    "command_timeout_seconds": 20,
    "default_log_lines": 100,
    "max_log_lines": 250,
    "shell_enabled": true,
    "shell_commands": {
      "uptime": "uptime",
      "disk_free": "df -h /",
      "mem_free": "free -m",
      "cpu_temp": "vcgencmd measure_temp || cat /sys/class/thermal/thermal_zone0/temp",
      "mqtt_check": "ss -ltnp | grep 1883 || true"
    },
    "systemctl_enabled": true,
    "systemctl_allow_services": [
      "clawkangsar.service",
      "home-assistant@homeassistant.service",
      "zigbee2mqtt.service",
      "mosquitto.service",
      "node-red.service"
    ],
    "docker_enabled": true,
    "docker_allow_containers": [
      "homeassistant",
      "zigbee2mqtt",
      "mosquitto",
      "nodered"
    ],
    "journal_enabled": true,
    "journal_allow_units": [
      "clawkangsar.service",
      "home-assistant@homeassistant.service",
      "zigbee2mqtt.service",
      "mosquitto.service",
      "node-red.service"
    ]
  }
}
